# 19. Intense --file sentinel (-- )
log_test "19. Intense --file sentinel (-- )"
setup_test
TARGET=$(git log --all --format="%H" --grep="master: commit 2")
git checkout master >> "$LOG" 2>&1
echo "inject_me" > inject_file.txt
git add inject_file.txt >> "$LOG" 2>&1
log_cmd "$INJECT_CMD" --file inject_file.txt -- --into "$TARGET"
NEW_TARGET=$(git log master -1 --format="%H" --grep="master: commit 2")
if git show "$NEW_TARGET" | grep -q "inject_me"; then
    pass "Test 19"
else
    fail "Test 19" "Sentinel parsing failed to stop file consumption"
fi
teardown_test
log_end

if [ "$FAILED_TESTS" -gt 0 ]; then
    echo -e "\nEvaluation complete with $FAILED_TESTS failures. Check test/SUMMARY_${DATETIME}.md and test/REPORT_${DATETIME}.md for details."
    exit 1
else
    echo -e "\nEvaluation complete! All tests passed. Check test/SUMMARY_${DATETIME}.md and test/REPORT_${DATETIME}.md for details."
    exit 0
fi
