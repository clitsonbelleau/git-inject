#!/usr/bin/env bash

# test/evaluation
# Intense Human-Behavior Mimicking Evaluation Harness for git-inject

if [ ! -f "git-inject" ] || [ ! -f "test/sandbox" ]; then
    echo "Please run this script from the root of the repository."
    exit 1
fi

DATE=$(date +"%Y%m%d")
TIME=$(date +"%H%M%S")

TEST_DIR="$(pwd)/test/eval_${DATE}"
EVAL_DIR="${TEST_DIR}/sandbox_${TIME}"
SAND_DIR="${EVAL_DIR}/git-inject-sandbox"

SANDBOX_CMD="$(pwd)/test/sandbox"
INJECT_CMD="$(pwd)/git-inject"

REPORT="${EVAL_DIR}/REPORT_${DATE}_${TIME}.log"
SUMMARY="${EVAL_DIR}/SUMMARY_${DATE}_${TIME}.md"

mkdir -p "$EVAL_DIR"

echo "# Git-Inject Test Experiment Report" > "$REPORT"
echo "Date: $(date)" >> "$REPORT"
echo "---" >> "$REPORT"
echo >> "$REPORT"

echo "# Git-Inject Test Summary" > "$SUMMARY"
echo "Date: $(date)" >> "$SUMMARY"
echo "---" >> "$SUMMARY"


log_cmd() {
    echo "$ $@" >> "$REPORT"
    "$@" >> "$REPORT" 2>&1
}

log_test() {
    echo -e "\nTest: $1"
    echo "========================================" >> "$REPORT"
    echo "TEST: $1" >> "$REPORT"
    echo "========================================" >> "$REPORT"
}

FAILED_TESTS=0

pass() {
    echo "- [x] **PASSED**: $1" | tee -a "$SUMMARY"
}

fail() {
    echo "- [ ] **FAILED**: $1 - $2" | tee -a "$SUMMARY"
    FAILED_TESTS=$((FAILED_TESTS + 1))
}

export GIT_AUTHOR_NAME="Test User"
export GIT_AUTHOR_EMAIL="test@example.com"
export GIT_COMMITTER_NAME="Test User"
export GIT_COMMITTER_EMAIL="test@example.com"

cd "$EVAL_DIR" || exit 1
if [ ! -d "git-inject-sandbox" ]; then
    echo "Sandbox not found, creating..." >> "$REPORT"
    "$SANDBOX_CMD" setup >> "$REPORT" 2>&1
fi
cd "$SAND_DIR" || exit 1

# 1. Intense Deep Tree Cross-Branch Copy (article to master)
test_name="1. Deep Tree Cross-Branch Copy (article to master)"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="master: commit 3")
PATCH=$(git log --all --format="%H" --grep="article: commit 4")
# Human behavior: User is working on 'article' branch, dirty tree, decides to copy a patch to 'master'
git checkout article >> "$REPORT" 2>&1
echo "dirty" > human_dirty_file.txt
log_cmd "$INJECT_CMD" "$TARGET" "$PATCH" --copy -b master
NEW_TARGET=$(git log master -1 --format="%H" --grep="master: commit 3")
if git show "$NEW_TARGET" --name-only | grep -q "article_4.csv"; then
    if [ -f "human_dirty_file.txt" ] && [ "$(git branch --show-current)" = "article" ]; then
        pass "$test_name"
    else
        fail "$test_name" "Did not maintain dirty state or branch correctly"
    fi
else
    fail "$test_name" "article_4.csv not found in master history"
fi


# 2. Intense Working Tree (-w) on docs branch
test_name="2. Intense Working Tree (-w) on docs branch"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="docs: commit 4")
git checkout docs >> "$REPORT" 2>&1
# Human behavior: User tracks a new file, modifies existing, deletes another, and leaves one untracked
echo "new_tracked" > new_tracked.txt
git add new_tracked.txt >> "$REPORT" 2>&1
echo "modified" >> docs_1.txt
git rm docs_2.md >> "$REPORT" 2>&1
echo "untracked" > untracked.txt
log_cmd "$INJECT_CMD" -w "$TARGET"
NEW_TARGET=$(git log -1 --format="%H" --grep="docs: commit 4")
if git show "$NEW_TARGET" | grep -q "new_tracked" && \
   git show "$NEW_TARGET" | grep -q "modified" && \
   git show "$NEW_TARGET" | grep -q "untracked" && \
   ! git ls-tree -r "$NEW_TARGET" | grep -q "docs_2.md"; then
    pass "$test_name"
else
    fail "$test_name" "Working tree changes (tracked/modified/deleted/untracked) not properly injected"
fi


# 3. Intense Staged (-s) with conflicting unstaged changes on feature branch
test_name="3. Intense Staged (-s) on feature branch"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="feature: commit 2")
git checkout feature >> "$REPORT" 2>&1
# Human behavior: stage part of a file, leave the rest unstaged
echo "staged_change" > feature_1.txt
git add feature_1.txt >> "$REPORT" 2>&1
echo "unstaged_change" >> feature_1.txt
log_cmd "$INJECT_CMD" -s "$TARGET"
NEW_TARGET=$(git log -1 --format="%H" --grep="feature: commit 2")
if git show "$NEW_TARGET" | grep -q "staged_change" && ! git show "$NEW_TARGET" | grep -q "unstaged_change"; then
    if grep -q "unstaged_change" feature_1.txt; then
        pass "$test_name"
    else
        fail "$test_name" "Unstaged changes were lost from working tree"
    fi
else
    fail "$test_name" "Staged changes injected improperly"
fi


# 4. Intense Conflict Generation, Switch branches midway, Continue
test_name="4. Conflict Generation & Multi-branch Continue"
log_test "$test_name"
git checkout reference >> "$REPORT" 2>&1
TARGET=$(git log --all --format="%H" --grep="reference: commit 2")
# Create conflict scenario on reference
git checkout -b reference_conflict "$TARGET" >> "$REPORT" 2>&1
echo "conflict reference" > topic_3.json
git add topic_3.json >> "$REPORT" 2>&1
git commit -m "Conflict Target Ref" >> "$REPORT" 2>&1
TARGET_C=$(git rev-parse HEAD)
echo "dummy" > dummy.txt
git add dummy.txt >> "$REPORT" 2>&1
git commit -m "Dummy Ref" >> "$REPORT" 2>&1

git checkout topic >> "$REPORT" 2>&1
echo "conflict topic" > topic_3.json
git add topic_3.json >> "$REPORT" 2>&1
git commit -m "Conflict Patch Topic" >> "$REPORT" 2>&1
PATCH_C=$(git rev-parse HEAD)

git checkout reference_conflict >> "$REPORT" 2>&1
log_cmd "$INJECT_CMD" "$TARGET_C" "$PATCH_C" -b reference_conflict
# Human behavior: context switch midway through conflict
git checkout master >> "$REPORT" 2>&1
git checkout reference_conflict >> "$REPORT" 2>&1
echo "resolved" > topic_3.json
git add topic_3.json >> "$REPORT" 2>&1
log_cmd "$INJECT_CMD" --continue
NEW_TARGET=$(git log -1 --format="%H" --grep="Conflict Target Ref")
if git show "$NEW_TARGET" | grep -q "resolved"; then
    pass "$test_name"
else
    fail "$test_name" "Failed to resolve conflict after context switch"
fi


# 5. Intense Conflict Abort (--abort)
test_name="5. Intense Conflict Abort (--abort)"
log_test "$test_name"
git checkout article >> "$REPORT" 2>&1
TARGET=$(git log --all --format="%H" --grep="article: commit 2")
git checkout -b article_conflict "$TARGET" >> "$REPORT" 2>&1
echo "conflict A" > article_1.txt
git add article_1.txt >> "$REPORT" 2>&1
git commit -m "Conflict Target Article" >> "$REPORT" 2>&1
TARGET_C=$(git rev-parse HEAD)
echo "dummy" > dummy.txt
git add dummy.txt >> "$REPORT" 2>&1
git commit -m "Dummy Art" >> "$REPORT" 2>&1
ORIG_HEAD=$(git rev-parse HEAD)

git checkout docs >> "$REPORT" 2>&1
echo "conflict B" > article_1.txt
git add article_1.txt >> "$REPORT" 2>&1
git commit -m "Conflict Patch Docs" >> "$REPORT" 2>&1
PATCH_C=$(git rev-parse HEAD)

git checkout article_conflict >> "$REPORT" 2>&1
log_cmd "$INJECT_CMD" "$TARGET_C" "$PATCH_C" -b article_conflict
# Human behavior: messes around, deletes files, then panics and aborts
rm -f article_1.txt
echo "mess" > dummy.txt
log_cmd "$INJECT_CMD" --abort
if [ "$(git rev-parse article_conflict)" = "$ORIG_HEAD" ]; then
    pass "$test_name"
else
    fail "$test_name" "Abort failed to cleanly restore branch state"
fi


# 6. Intense Revert (--revert) crossing branches
test_name="6. Intense Revert crossing branches"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="master: commit 2")
PATCH=$(git log --all --format="%H" --grep="feature: commit 5")
git checkout feature >> "$REPORT" 2>&1
ORIG_MASTER=$(git rev-parse master)
log_cmd "$INJECT_CMD" "$TARGET" "$PATCH" --copy -b master
# Revert from feature branch!
log_cmd "$INJECT_CMD" --revert
if [ "$(git rev-parse master)" = "$ORIG_MASTER" ] && [ "$(git branch --show-current)" = "feature" ]; then
    pass "$test_name"
else
    fail "$test_name" "Revert did not accurately cross branches"
fi


# 7. Intense Detached HEAD handling
test_name="7. Detached HEAD edge case"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="topic: commit 2")
PATCH=$(git log --all --format="%H" --grep="topic: commit 4")
git checkout topic~2 >> "$REPORT" 2>&1 # detached
log_cmd "$INJECT_CMD" "$TARGET" "$PATCH"
if grep -q "detached HEAD state" "$REPORT"; then
    pass "$test_name"
else
    fail "$test_name" "Failed to catch detached HEAD"
fi


# 8. Intense Strategy --theirs across master/docs
test_name="8. Strategy --theirs"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="master: commit 2")
git checkout -b strategy_conflict "$TARGET" >> "$REPORT" 2>&1
echo "master content" > docs_5.yml
git add docs_5.yml >> "$REPORT" 2>&1
git commit -m "Conflict Target Strategy" >> "$REPORT" 2>&1
TARGET_C=$(git rev-parse HEAD)
echo "dummy" > dummy.txt
git add dummy.txt >> "$REPORT" 2>&1
git commit -m "Dummy Strategy" >> "$REPORT" 2>&1

git checkout docs >> "$REPORT" 2>&1
echo "docs content" > docs_5.yml
git add docs_5.yml >> "$REPORT" 2>&1
git commit -m "Conflict Patch Strategy" >> "$REPORT" 2>&1
PATCH_C=$(git rev-parse HEAD)

git checkout strategy_conflict >> "$REPORT" 2>&1
log_cmd "$INJECT_CMD" "$TARGET_C" "$PATCH_C" -b strategy_conflict --theirs
NEW_TARGET=$(git log strategy_conflict -1 --format="%H" --grep="Conflict Target Strategy")
if git show "$NEW_TARGET" | grep -q "docs content"; then
    pass "$test_name"
else
    fail "$test_name" "Strategy --theirs failed to override"
fi


# 9. Intense Clear State (--clear) manually aborted
test_name="9. Manual Abort & Clear State (--clear)"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="article: commit 2")
git checkout -b clear_conflict "$TARGET" >> "$REPORT" 2>&1
echo "conflict A" > article_1.txt
git add article_1.txt >> "$REPORT" 2>&1
git commit -m "Conflict Target Clear" >> "$REPORT" 2>&1
TARGET_C=$(git rev-parse HEAD)

git checkout article >> "$REPORT" 2>&1
echo "conflict B" > article_1.txt
git add article_1.txt >> "$REPORT" 2>&1
git commit -m "Conflict Patch Clear" >> "$REPORT" 2>&1
PATCH_C=$(git rev-parse HEAD)

git checkout clear_conflict >> "$REPORT" 2>&1
log_cmd "$INJECT_CMD" "$TARGET_C" "$PATCH_C" -b clear_conflict
# User abandons using git native commands
git rebase --abort >> "$REPORT" 2>&1
git cherry-pick --abort >> "$REPORT" 2>&1 || true
log_cmd "$INJECT_CMD" --clear
if [ ! -d ".git/INJECT_STATE" ]; then
    pass "$test_name"
else
    fail "$test_name" "State not cleared"
fi


# 10. Intense Implicit Patch on Reference
test_name="10. Implicit Patch on Reference"
log_test "$test_name"
git checkout reference >> "$REPORT" 2>&1
TARGET=$(git log --all --format="%H" --grep="reference: commit 1")
PATCH=$(git log --all --format="%H" --grep="reference: commit 5")
git reset --hard "$PATCH" >> "$REPORT" 2>&1
log_cmd "$INJECT_CMD" "$TARGET"
NEW_TARGET=$(git log reference -1 --format="%H" --grep="reference: commit 1")
if git show "$NEW_TARGET" --name-only | grep -q "reference_5.yml"; then
    pass "$test_name"
else
    fail "$test_name" "Implicit patch failed on reference"
fi

# 11. Recursive Guard Test
test_name="11. Recursive Guard Test"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="master: commit 2")
git checkout -b recursive_conflict "$TARGET" >> "$REPORT" 2>&1
echo "conflict A" > master_1.txt
git add master_1.txt >> "$REPORT" 2>&1
git commit -m "Conflict Target Rec" >> "$REPORT" 2>&1
TARGET_C=$(git rev-parse HEAD)

git checkout master >> "$REPORT" 2>&1
echo "conflict B" > master_1.txt
git add master_1.txt >> "$REPORT" 2>&1
git commit -m "Conflict Patch Rec" >> "$REPORT" 2>&1
PATCH_C=$(git rev-parse HEAD)

git checkout topic >> "$REPORT" 2>&1
log_cmd "$INJECT_CMD" "$TARGET_C" "$PATCH_C" -b recursive_conflict
# Now, try to start another injection
log_cmd "$INJECT_CMD" "$TARGET_C" "$PATCH_C"
if grep -q "already in progress" "$REPORT"; then
    pass "$test_name"
else
    fail "$test_name" "Recursive guard did not block second injection"
fi


# 12. Merge-Bubble Integrity
test_name="12. Merge-Bubble Integrity"
log_test "$test_name"
git checkout master >> "$REPORT" 2>&1
git checkout -b feature_bubble master~3 >> "$REPORT" 2>&1
echo "bubble" > bubble.txt
git add bubble.txt >> "$REPORT" 2>&1
git commit -m "Bubble Commit" >> "$REPORT" 2>&1
BUBBLE_COMMIT=$(git rev-parse HEAD)
git checkout master >> "$REPORT" 2>&1
git merge --no-ff feature_bubble -m "Merge bubble" >> "$REPORT" 2>&1
MERGE_COMMIT=$(git rev-parse HEAD)

# Inject into master~6 (before the bubble)
TARGET=$(git log --all --format="%H" --grep="master: commit 4")
PATCH=$(git log --all --format="%H" --grep="master: commit 10")
log_cmd "$INJECT_CMD" "$TARGET" "$PATCH"
if git log --merges | grep -q "Merge bubble"; then
    pass "$test_name"
else
    fail "$test_name" "Merge bubble was flattened during rebase"
fi


# 13. Pre-existing Stash Stack Stress
test_name="13. Pre-existing Stash Stack Stress"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="docs: commit 4")
git checkout docs >> "$REPORT" 2>&1
# Push 3 dummy stashes
echo "stash1" > stash1.txt; git add stash1.txt >> "$REPORT" 2>&1; git stash push -m "stash1" >> "$REPORT" 2>&1
echo "stash2" > stash2.txt; git add stash2.txt >> "$REPORT" 2>&1; git stash push -m "stash2" >> "$REPORT" 2>&1
echo "stash3" > stash3.txt; git add stash3.txt >> "$REPORT" 2>&1; git stash push -m "stash3" >> "$REPORT" 2>&1
INITIAL_STASH_COUNT=$(git stash list | wc -l)

echo "new_tracked" > new_tracked.txt
git add new_tracked.txt >> "$REPORT" 2>&1
log_cmd "$INJECT_CMD" -w "$TARGET"
FINAL_STASH_COUNT=$(git stash list | wc -l)

if [ "$INITIAL_STASH_COUNT" -eq "$FINAL_STASH_COUNT" ]; then
    pass "$test_name"
else
    fail "$test_name" "Stash stack count changed from $INITIAL_STASH_COUNT to $FINAL_STASH_COUNT"
fi


# 14. Deep Subdirectory Invocation
test_name="14. Deep Subdirectory Invocation"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="master: commit 5")
git checkout master >> "$REPORT" 2>&1
mkdir -p src/components/styles
cd src/components/styles || exit 1
echo "deep_untracked" > deep.txt
log_cmd "$INJECT_CMD" -w "$TARGET"
cd ../../.. || exit 1
NEW_TARGET=$(git log -1 --format="%H" --grep="master: commit 5")
if git show "$NEW_TARGET" | grep -q "deep_untracked"; then
    pass "$test_name"
else
    fail "$test_name" "Deep subdirectory changes not injected"
fi

# 15. Gitignore Respect Test
test_name="15. Gitignore Respect Test"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="master: commit 5")
git checkout master >> "$REPORT" 2>&1
echo "ignored_file.tmp" > .gitignore
git add .gitignore && git commit -m "Add gitignore" >> "$REPORT" 2>&1
echo "should_be_ignored" > ignored_file.tmp
log_cmd "$INJECT_CMD" -w "$TARGET"
NEW_TARGET=$(git log -1 --format="%H" --grep="master: commit 5")
if ! git ls-tree -r "$NEW_TARGET" | grep -q "ignored_file.tmp"; then
    pass "$test_name"
else
    fail "$test_name" "Ignored file was incorrectly injected into history"
fi

# 16. Intense --into flag combinations
test_name="16. Intense --into flag combinations"
log_test "$test_name"
git checkout master >> "$REPORT" 2>&1
TARGET=$(git log --all --format="%H" --grep="master: commit 2")
PATCH=$(git log --all --format="%H" --grep="master: commit 5")
# Test <patch> --into <target>
log_cmd "$INJECT_CMD" "$PATCH" --into "$TARGET"
NEW_TARGET=$(git log master -1 --format="%H" --grep="master: commit 2")
if git show "$NEW_TARGET" --name-only | grep -q "master_5"; then
    pass "$test_name"
else
    fail "$test_name" "--into parsing failed with <patch> --into <target>"
fi


# 17. Intense --file flag (selective working tree injection)
test_name="17. Intense --file flag (selective working tree injection)"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="master: commit 2")
git checkout master >> "$REPORT" 2>&1
echo "inject_me" > inject_file.txt
echo "leave_me" > leave_file.txt
git add inject_file.txt leave_file.txt >> "$REPORT" 2>&1
log_cmd "$INJECT_CMD" "$TARGET" --file inject_file.txt
NEW_TARGET=$(git log master -1 --format="%H" --grep="master: commit 2")
if git show "$NEW_TARGET" | grep -q "inject_me" && ! git show "$NEW_TARGET" | grep -q "leave_me"; then
    if [ -f "leave_file.txt" ] && grep -q "leave_me" leave_file.txt; then
        pass "$test_name"
    else
        fail "$test_name" "Uninjected file changes were lost from working tree"
    fi
else
    fail "$test_name" "Selective file injection failed"
fi


# 18. Intense --file flag validation
test_name="18. Intense --file flag validation"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="master: commit 2")
git checkout master >> "$REPORT" 2>&1
echo "test" > inject_file.txt
git add inject_file.txt >> "$REPORT" 2>&1
log_cmd "$INJECT_CMD" "$TARGET" HEAD~1 --file inject_file.txt
if grep -q "cannot be used with an explicit <patch>" "$REPORT"; then
    log_cmd "$INJECT_CMD" "$TARGET" --file missing_file.txt
    if grep -q "do not exist" "$REPORT"; then
        pass "$test_name"
    else
        fail "$test_name" "Failed to catch missing file error"
    fi
else
    fail "$test_name" "Failed to catch explicit patch error"
fi


# 19. Intense --file sentinel (-- )
test_name="19. Intense --file sentinel (-- )"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="master: commit 2")
git checkout master >> "$REPORT" 2>&1
echo "inject_me" > inject_file.txt
git add inject_file.txt >> "$REPORT" 2>&1
log_cmd "$INJECT_CMD" --file inject_file.txt -- --into "$TARGET"
NEW_TARGET=$(git log master -1 --format="%H" --grep="master: commit 2")
if git show "$NEW_TARGET" | grep -q "inject_me"; then
    pass "$test_name"
else
    fail "$test_name" "Sentinel parsing failed to stop file consumption"
fi

# 20. Intense --file with spaces and quotes
test_name="20. Intense --file with spaces and quotes"
log_test "$test_name"
git checkout master >> "$REPORT" 2>&1
echo "weird" > "weird ' file .txt"
git add "weird ' file .txt" >> "$REPORT" 2>&1
git commit -m "Add weird file" >> "$REPORT" 2>&1
echo "more weird" > "weird ' file .txt"
log_cmd "$INJECT_CMD" HEAD --file "weird ' file .txt"
if git show HEAD | grep -q "more weird"; then
    pass "$test_name"
else
    fail "$test_name" "Failed to handle spaces and quotes in --file"
fi


# 21. Intense --file with deleted file
test_name="21. Intense --file with deleted file"
log_test "$test_name"
TARGET=$(git log --all --format="%H" --grep="master: commit 2")
git checkout master >> "$REPORT" 2>&1
rm master_3.json
log_cmd "$INJECT_CMD" "$TARGET" --file master_3.json
NEW_TARGET=$(git log master -1 --format="%H" --grep="master: commit 2")
if ! git ls-tree -r "$NEW_TARGET" | grep -q "master_3.json"; then
    pass "$test_name"
else
    fail "$test_name" "Failed to inject file deletion"
fi


# 22. Intense empty commit injection into empty target
test_name="22. Intense empty commit injection into empty target"
log_test "$test_name"
git checkout master >> "$REPORT" 2>&1
git commit --allow-empty -m "Empty Target" >> "$REPORT" 2>&1
TARGET_E=$(git rev-parse HEAD)
git commit --allow-empty -m "Empty Patch" >> "$REPORT" 2>&1
PATCH_E=$(git rev-parse HEAD)
log_cmd "$INJECT_CMD" "$TARGET_E" "$PATCH_E" --is-empty
NEW_TARGET=$(git log master -1 --format="%H" --grep="Empty Target")
if [ -n "$NEW_TARGET" ]; then
    pass "$test_name"
else
    fail "$test_name" "Failed to inject empty patch into empty target"
fi


# 23. Intense Mid-Rebase Safety Check
test_name="23. Intense Mid-Rebase Safety Check"
log_test "$test_name"
git checkout master >> "$REPORT" 2>&1
GIT_SEQUENCE_EDITOR="sed -i '1s/^pick/edit/'" git rebase -i HEAD~2 >> "$REPORT" 2>&1
TARGET_R=$(git rev-parse HEAD)
log_cmd "$INJECT_CMD" "$TARGET_R" HEAD~1
if grep -q "already in progress" "$REPORT"; then
    git rebase --abort >> "$REPORT" 2>&1
    pass "$test_name"
else
    git rebase --abort >> "$REPORT" 2>&1
    fail "$test_name" "Did not gracefully fail when native rebase is in progress"
fi

# teardown_test
# cd ../../.. || exit 1

if [ "$FAILED_TESTS" -gt 0 ]; then
    echo -e "\nEvaluation complete with $FAILED_TESTS failures. Check test/eval_${DATE}/SUMMARY_${DATE}_${TIME}.md and test/eval_${DATE}/REPORT_${DATE}_${TIME}.log for details."
    exit 1
else
    echo -e "\nEvaluation complete! All tests passed. Check test/eval_${DATE}/SUMMARY_${DATE}_${TIME}.md and test/eval_${DATE}/REPORT_${DATE}_${TIME}.log for details."
    exit 0
fi
