if ! GIT_DIR="$(git rev-parse --absolute-git-dir 2>/dev/null)"; then
    printf "fatal: not a git repository\n"
    exit 1
fi

# Store the state of the injection process
STATE_DIR="$GIT_DIR/INJECT_STATE"
LOCK_FILE="$GIT_DIR/INJECT_LOCK"
REVERT_HEAD="$GIT_DIR/INJECT_REVERT"
REVERT_BRANCH="$GIT_DIR/INJECT_BRANCH"
BACKUP_HEAD="$STATE_DIR/BACKUP_HEAD"

# Ensure cleanup happens on unexpected exit
# but only for states that are not meant to be resumed
CLEANUP_ON_EXIT=true

cleanup_trap() {
    if [ "$CLEANUP_ON_EXIT" = "true" ]; then
        if [ -d "$STATE_DIR" ]; then
            if [ -f "$GIT_DIR/CHERRY_PICK_HEAD" ]; then
                git cherry-pick --abort >/dev/null 2>&1
                rm -f "$GIT_DIR/CHERRY_PICK_HEAD"
            fi
            if [ -d "$GIT_DIR/rebase-merge" ] || [ -d "$GIT_DIR/rebase-apply" ]; then
                git rebase --abort >/dev/null 2>&1
                rm -rf "$GIT_DIR/rebase-merge" "$GIT_DIR/rebase-apply"
            fi
            inject_cleanup
        fi
    fi
    [ -f "$LOCK_FILE" ] && rm -f "$LOCK_FILE"
}

trap cleanup_trap EXIT

acquire_lock() {
    if [ -f "$LOCK_FILE" ]; then
        local pid
        pid="$(cat "$LOCK_FILE" 2>/dev/null)"
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            # MINGW*|MSYS*|CYGWIN* systems are unpredictable
            # Verify the PID actually belongs to a bash or git process
            if ps -p "$pid" 2>/dev/null | grep -iqE "bash|git"; then
                printf "fatal: Another git-inject process (PID %s) is running.\n" "$pid"
                exit 1
            fi
        fi
        # Remove stale lockfile
        rm -f "$LOCK_FILE"
    fi
    echo "$$" > "$LOCK_FILE"
}

usage() {
    cat << EOF
git-inject  Copyright (C) 2026  Clitson Belleau

This program comes with ABSOLUTELY NO WARRANTY. This is
free software, and you are welcome to redistribute it
under the conditions of the license provided.

Usage: git inject <target> [<patch>]
   or: git inject [<target>] (--working-tree | --staged)
   or: git inject [<target>] --file [FILE...]
   or: git inject (--continue | --abort | --revert | --clear)

       <target> is required unless otherwise stated as optional.
       <patch> is an optional requirement (defaults to HEAD).

       Run 'git help inject' to view the manual.
EOF
}

___DISPLAY_STATUS___() {
    echo "----------------"
    git status -s
    echo "----------------"
}

inject_autostash(){
    local old_stash
    local new_stash

    # Create state directory in case of using working tree or staged changes
    mkdir -p "$STATE_DIR"

    old_stash="$(parse --quiet --verify refs/stash)"
    git stash push --include-untracked --message="INJECT: Save working tree" --quiet >/dev/null 2>&1
    new_stash="$(parse --quiet --verify refs/stash)"

    if [ "$old_stash" != "$new_stash" ]; then
        echo "$new_stash" > "$STATE_DIR/stash"
    else
        rm -f "$STATE_DIR/stash"
    fi
}

inject_cleanup() {
    CLEANUP_ON_EXIT=false
    # Load persisted flags
    [ -f "$STATE_DIR/use_working_tree" ] && use_working_tree=true
    [ -f "$STATE_DIR/use_staged" ] && use_staged=true
    [ -f "$STATE_DIR/use_file" ] && use_file=true

    # Return to the invocation branch before popping stash
    if [ -f "$STATE_DIR/ORIG_BRANCH" ]; then
        origin="$(cat "$STATE_DIR/ORIG_BRANCH" 2>/dev/null)"
        if [ -n "$origin" ] && [ "$(git branch --show-current)" != "$origin" ]; then
            if git switch "$origin" >/dev/null 2>&1 || git checkout "$origin" >/dev/null 2>&1; then
                printf "Returned to branch '%s'\n" "$origin"
            else
                printf "error: Failed to return to branch '%s'\n" "$origin"
            fi
        fi
    fi

    # Handle the temporary commit
    if [ -s "$STATE_DIR/INDEX_HEAD" ]; then
        patch="$(<"$STATE_DIR/PATCH")"
        if [ "$(parse HEAD)" = "$patch" ]; then
            if [ "$1" = "abort" ]; then
                # Recover changes after abort
                git reset HEAD^ >/dev/null 2>&1
            else
                # Drop temporary commit upon success
                git reset --hard HEAD^ >/dev/null 2>&1
            fi
        fi
    fi

    if [ -f "$STATE_DIR/stash" ]; then
        if [ "$use_working_tree" = true ] && [ "$use_file" != true ]; then
            git stash drop --quiet
        else
            git stash pop --quiet
        fi
    fi
    [ -d "$STATE_DIR" ] && rm -rf "$STATE_DIR"
}

parse() {
    if [ "$1" = "-s" ]; then
        git rev-parse --short "$2"
    else
        git rev-parse "$@"
    fi
}

verify() {
  parse --verify "$@"
}

inject_success() {
    target_old="$(cat "$STATE_DIR/TARGET" 2>/dev/null)"
    target_new="$(cat "$STATE_DIR/TARGET_NEW" 2>/dev/null)"

    if [ -n "$target_old" ] && [ -n "$target_new" ]; then
        patch="$(cat "$STATE_DIR/PATCH" 2>/dev/null)"
        [ -z "$patch" ] && patch="CHANGES" || patch="$(parse -s "$patch")"
        echo "----------------"
        printf "Injected %s -> %s\n" "$patch" "$(parse -s "$target_old")"
        printf " Updated %s -> %s\n" "$(parse -s "$target_old")" "$(parse -s "$target_new")"
        git diff -z --name-only "$target_old".."$target_new" | xargs -0 git diff --stat "$target_old".."$target_new" --
    fi

    printf "Successfully injected patch.\n"
    inject_cleanup
}

get_strategy_options() {
    [ -f "$STATE_DIR/theirs" ] && printf -- "-X theirs"
}

# Automatically marks target for 'edit' and patch for 'drop'.
# If --copy is set, the patch is unchanged.
export_sequence_editor() {
    target="$(<"$STATE_DIR/TARGET")"
    patch="$(<"$STATE_DIR/PATCH")"
    copy_mode="false"
    [ -f "$STATE_DIR/copy" ] && copy_mode="true"

    # Temporary script to handle the sequence editing
    cat << EOF > "$STATE_DIR/editor.sh"
#!/usr/bin/env bash
awk -v t="$target" -v p="$patch" -v c="$copy_mode" '
    \$1 ~ /^(pick|p)\$/ {
        if (length(\$2) >= 7) {
            if (index(t, \$2) == 1) \$1 = "edit"
            if (c == "false" && index(p, \$2) == 1) { next }
        }
    }
    { print }
' "\$1" > "\$1.tmp" && mv "\$1.tmp" "\$1"
EOF
    chmod +x "$STATE_DIR/editor.sh"

    case "$(uname -s)" in
        MINGW*|MSYS*|CYGWIN*)
            export GIT_SEQUENCE_EDITOR="bash \"$STATE_DIR/editor.sh\""
            ;;
        Linux*|Darwin*)
            export GIT_SEQUENCE_EDITOR="$STATE_DIR/editor.sh"
            ;;
        *)
            echo "Unknown operating system"
            exit 1
            ;;
    esac
}

start_injection() {
    options="$(get_strategy_options)"
    target="$(<"$STATE_DIR/TARGET")"
    target_branch="$(<"$STATE_DIR/TARGET_BRANCH")"

    export_sequence_editor

    printf "Injection target: %s\n" "$target"

    # If the user tries to inject changes into the very first commit of the
    # repository, $target^ will fail to resolve because it has no parent.
    if verify "$target^" >/dev/null 2>&1; then
        rebase_start="$target^"
    else
        rebase_start="--root"
    fi
    if ! git rebase --rebase-merges -i $options "$rebase_start" "$target_branch" 2>/dev/null; then
        printf "\nCONFLICT during rebase initialization!\nResolve, then run: git inject --continue\n"
        CLEANUP_ON_EXIT=false
        exit 1
    fi

    process_rebase_step
}

process_rebase_step() {
    options="$(get_strategy_options)"
    patch="$(<"$STATE_DIR/PATCH")"
    target="$(<"$STATE_DIR/TARGET")"
    s_patch="$(parse -s "$patch")"
    s_target="$(parse -s "$target")"

    # Check if we stopped at our target for editing
    current_head="$(parse HEAD)"
    if [ "$(parse "$target")" = "$current_head" ]; then
        printf "Injecting %s -> %s...\n" "$s_patch" "$s_target"
        echo "INJECTING" > "$STATE_DIR/STATUS"
        if git cherry-pick $options --no-commit "$patch"; then
            finalize_injection
        else
            printf "\nCONFLICT during patch injection!\nResolve, then run: git inject --continue\n"
            CLEANUP_ON_EXIT=false
            exit 1
        fi
    else
        # Stopped somewhere else (possible generic conflict)
        echo "REBASING" > "$STATE_DIR/STATUS"
        export_sequence_editor
        if git rebase --continue; then
            inject_success
            exit 0
        else
            printf "\nCONFLICT during rebase!\nResolve, then run: git inject --continue\n"
            CLEANUP_ON_EXIT=false
            exit 1
        fi
    fi
}

finalize_injection() {
    target="$(<"$STATE_DIR/TARGET")"
    patch="$(<"$STATE_DIR/PATCH")"
    [ -f "$STATE_DIR/is_empty_commit" ] && is_empty_commit=true

    if git commit --amend $([ "$is_empty_commit" = true ] && echo "--allow-empty") --reuse-message="$target" --no-verify; then
        # Capture the new target hash
        parse HEAD > "$STATE_DIR/TARGET_NEW"

        echo "REBASING" > "$STATE_DIR/STATUS"
        export_sequence_editor
        if git rebase --continue; then
            inject_success
            exit 0
        else
            printf "\nCONFLICT during post-injection rebase!\nResolve, then run: git inject --continue\n"
            CLEANUP_ON_EXIT=false
            exit 1
        fi
    else
        printf "Error: could not commit changes into target.\n"
        CLEANUP_ON_EXIT=false
        exit 1
    fi
}

acquire_lock

case "$1" in
    --continue)
        if [ ! -d "$STATE_DIR" ]; then
            printf "No injection in progress.\n"
            exit 1
        fi

        status="$(cat "$STATE_DIR/STATUS" 2>/dev/null || echo "UNKNOWN")"
        [ -f "$STATE_DIR/is_empty_commit" ] && is_empty_commit=true
        options="$(get_strategy_options)"
        origin="$(<"$STATE_DIR/ORIG_HEAD")"
        patch="$(<"$STATE_DIR/PATCH")"
        target="$(<"$STATE_DIR/TARGET")"
        target_branch="$(<"$STATE_DIR/TARGET_BRANCH")"

        if [ "$status" = "INJECTING" ] || verify CHERRY_PICK_HEAD >/dev/null 2>&1; then
            printf "Finalizing injection...\n"
            git cherry-pick --quit >/dev/null 2>&1
            finalize_injection
            exit 0
        fi

        # Normal rebase continue
        export_sequence_editor
        if git rebase --continue; then
            inject_success
            exit 0
        else
            CLEANUP_ON_EXIT=false
            exit 1
        fi
        ;;
    --abort)
        if [ -d "$STATE_DIR" ]; then
            origin="$(<"$STATE_DIR/ORIG_BRANCH")"
            target_branch="$(<"$STATE_DIR/TARGET_BRANCH")"
            b_head="$(<"$BACKUP_HEAD")"
            git reset --hard HEAD >/dev/null 2>&1
            git cherry-pick --abort >/dev/null 2>&1
            git rebase --abort >/dev/null 2>&1
            rm -f "$GIT_DIR/CHERRY_PICK_HEAD"
            rm -rf "$GIT_DIR/rebase-merge" "$GIT_DIR/rebase-apply"
            # Reset history on target branch
            git switch "$target_branch" >/dev/null 2>&1
            [ -n "$b_head" ] && git reset --hard "$b_head" >/dev/null 2>&1
            printf "Injection aborted. Returned branch '%s' to %s.\n" "$target_branch" "$(parse -s "$b_head")"
            # Switch back to invocation branch and cleanup
            git switch "$origin" >/dev/null 2>&1
            inject_cleanup "abort"
        else
            printf "No active injection to abort.\n"
        fi
        exit 0
        ;;
    --revert)
        if [ ! -f "$REVERT_HEAD" ] && [ ! -f "$REVERT_BRANCH" ]; then
            printf "No revert information found.\n"
            exit 1
        fi
        [ -f "$REVERT_HEAD" ] || { printf "Missing revert HEAD.\n"; exit 1; }
        [ -f "$REVERT_BRANCH" ] || { printf "Missing revert branch.\n"; exit 1; }

        r_head=$(<"$REVERT_HEAD")
        r_branch=$(<"$REVERT_BRANCH")
        current_head=$(git branch --show-current)
        printf "Reverting %s to state before last injection (%s)...\n" "$r_branch" "$r_head"
        inject_autostash
        git switch "$r_branch" >/dev/null 2>&1
        git reset --hard "$r_head"
        git switch "$current_head" >/dev/null 2>&1
        rm -f "$REVERT_HEAD"
        rm -f "$REVERT_BRANCH"
        inject_cleanup
        exit 0
        ;;
     --clear)
        if [ ! -f "$REVERT_HEAD" ] && [ ! -f "$REVERT_BRANCH" ] && [ ! -d "$STATE_DIR" ]; then
            printf "No working files found.\n"
            exit 0
        fi
        [ -d "$STATE_DIR" ] && rm -rf "$STATE_DIR"
        [ -f "$REVERT_HEAD" ] && rm -f "$REVERT_HEAD"
        [ -f "$REVERT_BRANCH" ] && rm -f "$REVERT_BRANCH"
        [ -f "$LOCK_FILE" ] && rm -f "$LOCK_FILE"
        printf "Working files removed.\nStart an injection with 'git inject <target> <patch>'\n"
        exit 0
        ;;
esac

if [ -d "$STATE_DIR" ]; then
    CLEANUP_ON_EXIT=false
    cat << EOF
error: Injection in progress!

Handle conflicts before starting a new injection and then
use '--continue' to finish the injection process.

Use '--abort' to stop the current injection and '--clear'
to remove previous injection state. For more information
run 'git help inject'.
EOF
    exit 1
fi

# Init
patch=""
target=""
target_branch=""
use_working_tree=false
use_branch=false
use_copy=false
use_theirs=false
use_staged=false
use_file=false
is_empty_commit=false
use_dry_run=false
is_dry_run_child=false
into_target=""
positional_args=()
__dry_run_flags=()
inject_files=()

while [ $# -gt 0 ]; do
    case "$1" in
        -w | --working-tree)
            use_working_tree=true
            __dry_run_flags+=("$1")
            shift
            ;;
        --theirs)
            use_theirs=true
            __dry_run_flags+=("$1")
            shift
            ;;
        --copy | -c)
            use_copy=true
            __dry_run_flags+=("$1")
            shift
            ;;
        -b | --branch)
            target_branch="$2"
            use_branch=true
            __dry_run_flags+=("$1" "$2")
            shift 2
            ;;
        --into)
            into_target="$2"
            shift 2
            ;;
        --dry-run)
            use_dry_run=true
            shift
            ;;
        --is-dry-run-child)
            is_dry_run_child=true
            shift
            ;;
        --file)
            use_file=true
            __dry_run_flags+=("$1")
            shift
            missing_files=()
            while [ $# -gt 0 ]; do
                if [ "$1" = "--" ]; then
                    shift
                    break
                fi
                # Allow deleted but tracked files to be injected
                if ! git ls-files --error-unmatch "$1" >/dev/null 2>&1 && [ ! -e "$1" ]; then
                    missing_files+=("$1")
                else
                    inject_files+=("$1")
                    __dry_run_flags+=("$1")
                fi
                shift
            done
            if [ ${#inject_files[@]} -eq 0 ] && [ ${#missing_files[@]} -eq 0 ]; then
                printf "'--file' requires at least one file or directory.\n"
                exit 1
            fi
            if [ ${#missing_files[@]} -gt 0 ]; then
                printf "The following files or directories do not exist:\n"
                for missing_file in "${missing_files[@]}"; do
                    printf "  %s\n" "$missing_file"
                done
                exit 1
            fi
            ;;
        --clear)
            printf "Invalid use of '--clear'.\n"
            exit 1
            ;;
        -s | --staged)
            use_staged=true
            __dry_run_flags+=("$1")
            shift
            ;;
        --is-empty)
            is_empty_commit=true
            __dry_run_flags+=("$1")
            shift
            ;;
        --root)
            # parse --root commit
            root="$(git rev-list --max-parents=0 HEAD)"
            positional_args+=("$root")
            shift
            ;;
        -*)
            printf "Unknown option %s\n" "$1"
            exit 1
            ;;
        *)
            positional_args+=("$1")
            shift
            ;;
    esac
done

if [ "$use_dry_run" = true ]; then
    if [ "$__INJECT_DRY_RUN_ACTIVE" = "true" ]; then
        printf "Error: Nested dry-run detected.\n"
        exit 1
    fi

    printf "Performing dry-run (simulating injection)...\n"
    DRY_RUN_DIR=$(mktemp -d -t git-inject-dry-XXXXXX)
    trap 'rm -rf "$DRY_RUN_DIR"; exit 1' INT TERM EXIT

    # Lightweight clone
    git clone --local --shared --quiet . "$DRY_RUN_DIR"

    # Ship uncommitted changes if needed
    if [ "$use_working_tree" = true ] || [ "$use_staged" = true ] || [ "$use_file" = true ] || [ -n "$(git status --porcelain)" ]; then
        STASH_HASH=$(git stash create "DRY_RUN_TEMP")
        if [ -n "$STASH_HASH" ]; then
            (cd "$DRY_RUN_DIR" && git fetch .. "$STASH_HASH" --quiet && git stash apply "$STASH_HASH" --quiet)
        fi
    fi

    # Isolated execution
    (
        export __INJECT_DRY_RUN_ACTIVE=true
        unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE
        cd "$DRY_RUN_DIR" || exit 1
        bash "$0" "${positional_args[@]}" --is-dry-run-child "${__dry_run_flags[@]}"
    )
    RESULT=$?

    trap - INT TERM EXIT
    rm -rf "$DRY_RUN_DIR"

    if [ $RESULT -eq 0 ]; then
        printf "\nDRY-RUN SUCCESSFUL: The injection would complete without conflicts.\n"
    else
        printf "\nDRY-RUN FAILED: The injection would encounter conflicts or errors.\n"
    fi
    exit $RESULT
fi

if [ "$is_dry_run_child" = true ]; then
    # Suppress most output in child dry-run except errors
    exec >/dev/null
fi

# Resolve target and patch based on positional arguments and --into
if [ -n "$into_target" ]; then
    target="$into_target"
    if [ ${#positional_args[@]} -gt 1 ]; then
        printf "Too many arguments when using '--into'.\n"
        exit 1
    elif [ ${#positional_args[@]} -eq 1 ]; then
        patch="${positional_args[0]}"
    fi
else
    if [ ${#positional_args[@]} -gt 2 ]; then
        printf "Too many arguments.\n"
        exit 1
    elif [ ${#positional_args[@]} -eq 2 ]; then
        target="${positional_args[0]}"
        patch="${positional_args[1]}"
    elif [ ${#positional_args[@]} -eq 1 ]; then
        target="${positional_args[0]}"
    fi
fi

if [ "$use_file" = true ]; then
    if [ -n "$patch" ] && [ "$patch" != "HEAD" ]; then
        printf "'--file' cannot be used with an explicit <patch>.\n"
        exit 1
    fi
    if [ "$use_working_tree" = true ] || [ "$use_staged" = true ]; then
        printf "'--file' cannot be used with '--working-tree' or '--staged'.\n"
        exit 1
    fi

    # Check for unchanged files before any state changes
    unchanged_files=()
    for file in "${inject_files[@]}"; do
        if [ -z "$(git status --porcelain -- "$file")" ]; then
            unchanged_files+=("$file")
        fi
    done
    if [ ${#unchanged_files[@]} -gt 0 ]; then
        printf "The following files or directories have no changes:\n"
        for file in "${unchanged_files[@]}"; do
            printf "  %s\n" "$file"
        done
        exit 1
    fi
fi

if [ "$use_working_tree" = true ]; then
    if [ "$use_copy" = true ]; then
        printf "Cannot copy from working tree.\n"
        exit 1
    fi
    if [ -n "$patch" ] && [ "$patch" != "HEAD" ]; then
        printf "Using all changes in the working tree. Patch will be reset to head to HEAD.\n"
        printf "Verify arguments and run the command again.\n"
        exit 1
    fi
fi

if [ "$use_staged" = true ]; then
    if [ "$use_copy" = true ]; then
        printf "Cannot copy from index. Please commit your changes before copying.\n"
        exit 1
    fi
    if [ -n "$patch" ] && [ "$patch" != "HEAD" ]; then
        printf "Using staged changes. Patch will be reset to HEAD.\n"
        printf "Verify arguments and run the command again.\n"
        exit 1
    fi
fi

# If only target is specified, patch defaults to HEAD
if [ -n "$target" ] && [ -z "$patch" ]; then
    patch="HEAD"
fi

if [ -z "$target" ] && [ -z "$patch" ]; then
    if [ "$use_working_tree" = true ] || [ "$use_staged" = true ] || [ "$use_file" = true ]; then
        target="HEAD"
        patch="HEAD"
    else
        usage
        inject_cleanup
        exit 1
    fi
fi

if [ "$use_copy" = true ] && [ "$use_branch" = false ]; then
    printf "Can only copy onto another branch.\n"
    exit 1
fi

if [ -d "$GIT_DIR/rebase-merge" ] || [ -d "$GIT_DIR/rebase-apply" ] || [ -f "$GIT_DIR/CHERRY_PICK_HEAD" ]; then
    printf "A git operation (rebase/cherry-pick/am) is already in progress.\n"
    exit 1
fi

# Setup State
mkdir -p "$STATE_DIR"
# HEAD where git-inject was invoked
parse HEAD > "$STATE_DIR/ORIG_HEAD"
git branch --show-current > "$STATE_DIR/ORIG_BRANCH"
origin=$(<"$STATE_DIR/ORIG_BRANCH")
# Effective target branch for injection
touch "$STATE_DIR/TARGET_BRANCH"
touch "$STATE_DIR/INDEX_HEAD"

[ "$use_theirs" = true ] && touch "$STATE_DIR/theirs"
[ "$use_copy" = true ] && touch "$STATE_DIR/copy"
[ "$use_working_tree" = true ] && touch "$STATE_DIR/use_working_tree"
[ "$use_staged" = true ] && touch "$STATE_DIR/use_staged"
[ "$use_file" = true ] && touch "$STATE_DIR/use_file"
[ "$is_empty_commit" = true ] && touch "$STATE_DIR/is_empty_commit"

# Determine target branch
if [ -n "$target_branch" ]; then
    if ! git show-ref --verify --quiet "refs/heads/$target_branch"; then
        printf "Branch '%s' does not exist.\n" "$target_branch"
        exit 1
    fi
    echo "$target_branch" > "$STATE_DIR/TARGET_BRANCH"
else
    echo "$origin" > "$STATE_DIR/TARGET_BRANCH"
    target_branch=$(<"$STATE_DIR/TARGET_BRANCH")
    if [ -z "$target_branch" ]; then
        printf "You are in a detached HEAD state.\nStart git inject within a branch.\n"
        exit 1
    fi
fi

# Hash of the effective target branch name and HEAD to which we reset
# upon reverting the injection
parse "$target_branch" > "$REVERT_HEAD"
echo "$target_branch" > "$REVERT_BRANCH"

# Hash of the <target> commit
_t="$target"
if target="$(verify "$target" 2>/dev/null)"; then
    echo "$target" > "$STATE_DIR/TARGET"
else
    printf "Invalid target '%s'.\n" "$_t"
    exit 1
fi

if [ "$use_working_tree" = true ] || [ "$use_staged" = true ] || [ "$use_file" = true ]; then
    if [ "$use_staged" = true ]; then
        if git diff-index --cached --quiet HEAD --; then
            printf "No staged changes to inject.\n"
            exit 0
        fi
        ___DISPLAY_STATUS___
    fi

    if [ "$use_working_tree" = true ]; then
        if [ -z "$(git status --porcelain)" ]; then
            printf "No working directory changes to inject.\n"
            exit 0
        else
            inject_autostash
            git stash apply --quiet
            if [ "$use_working_tree" = true ]; then
                ___DISPLAY_STATUS___
            fi
        fi

        git add -A
        printf "Indexed working tree changes for injection.\n"
    fi

    if [ "$use_file" = true ]; then
        git reset HEAD --quiet
        git add -- "${inject_files[@]}"
        printf "Indexed specified files for injection:\n"
        for file in "${inject_files[@]}"; do
            printf "  %s\n" "$file"
        done
    fi

    if [ "$(parse HEAD)" = "$target" ]; then
        if git commit --amend $([ "$is_empty_commit" = true ] && echo "--allow-empty") --no-edit; then
            # Capture the new target hash
            parse HEAD > "$STATE_DIR/TARGET_NEW"
            inject_success
            exit 0
        else
            printf "Something unexpected happened.\n"
            exit 1
        fi
    else
        git commit -m "INJECT: Commit all changes for injection into $(parse -s "$target")" --quiet
        printf "Committed changes for injection (%s).\n" "$(parse -s "HEAD")"
    fi

    patch="HEAD"
    parse HEAD > "$STATE_DIR/INDEX_HEAD"
fi

# Hash of the <patch> commit
if patch="$(verify "$patch" 2>/dev/null)"; then
    echo "$patch" > "$STATE_DIR/PATCH"
else
    printf "Invalid patch '%s'.\n" "$patch"; exit 1
fi

if [ "$target" = "$patch" ]; then
    printf "Cannot inject into the same commit.\n"
    exit 1
fi

if ! git merge-base --is-ancestor "$target" "$target_branch" >/dev/null 2>&1; then
    printf "The target commit must exist on the branch \"%s\".\n" "$target_branch"
    exit 1
fi

if [ "$use_branch" = false ]; then
    if ! git merge-base --is-ancestor "$target" "$patch" >/dev/null 2>&1; then
        printf "The target commit must be an ancestor of the patch commit.\nSpecify --branch if injecting to a different branch.\n"
        exit 1
    fi

    if ! git merge-base --is-ancestor "$patch" "$target_branch" >/dev/null 2>&1; then
        printf "The patch must exist on the branch history of %s.\nSpecify --branch if injecting to a different branch.\n" "$target_branch"
        exit 1
    fi
fi

if [ "$use_working_tree" = false ]; then
    inject_autostash
fi

if [ "$target_branch" != "$origin" ]; then
    if git switch "$target_branch" >/dev/null 2>&1; then
        printf "Switched to branch '%s'\n" "$target_branch"
    else
        printf "error: Failed to switch to branch '%s'\n" "$target_branch"
        exit 1
    fi
fi

# Hash copy of the current HEAD on target branch.
parse HEAD > "$BACKUP_HEAD"

start_injection
